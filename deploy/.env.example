# Public host name that points at the VPS running docker compose.
DOMAIN=refraction.example.com

# Email address used by Caddy for Let's Encrypt certificate management.
ACME_EMAIL=you@example.com

# Hosted LiveKit instance used by the public Refraction deployment.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# Public frontend URL returned in viewer links minted by the backend.
PUBLIC_APP_BASE_URL=https://refraction.example.com

# Allowed browser origin for the public frontend.
CORS_ALLOWED_ORIGINS=https://refraction.example.com

# Optional: override the frontend API base URL at build time.
# Leave blank for the recommended same-origin /api reverse-proxy path.
VITE_API_BASE_URL=

# Optional room lifecycle overrides.
ROOM_SESSION_WAITING_TTL_MINUTES=15
ROOM_SESSION_LIVE_TTL_MINUTES=240
ROOM_SESSION_ENDED_RETENTION_MINUTES=10
ROOM_SESSION_CLEANUP_INTERVAL_SECONDS=30
